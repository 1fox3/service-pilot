{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Service Pilot",
  "version": "0.1.0",
  "identifier": "dev.servicepilot.app",
  "build": {
    "beforeDevCommand": "pnpm web:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm typecheck && pnpm web:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Service Pilot",
        "width": 1120,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.png"
    ]
  }
}
